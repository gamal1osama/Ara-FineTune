# Base Model to use
BASE_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# LLaMA-Factory local checkout and generated training config
LLAMAFACTORY_DIR=./LLaMA-Factory
LLAMAFACTORY_TRAIN_NAME=news_finetune_train
LLAMAFACTORY_VAL_NAME=news_finetune_val
LLAMAFACTORY_TRAIN_FILE=/gdrive/MyDrive/ara-finetune/datasets/llamafactory-finetune-data/train.json
LLAMAFACTORY_VAL_FILE=/gdrive/MyDrive/ara-finetune/datasets/llamafactory-finetune-data/val.json
LLAMAFACTORY_MODEL_NAME_OR_PATH=Qwen/Qwen2.5-1.5B-Instruct
LLAMAFACTORY_TEMPLATE=qwen
LLAMAFACTORY_CUTOFF_LEN=3500
LLAMAFACTORY_LORA_RANK=64
LLAMAFACTORY_LORA_TARGET=all
LLAMAFACTORY_TRAIN_BATCH_SIZE=1
LLAMAFACTORY_GRAD_ACCUMULATION_STEPS=4
LLAMAFACTORY_LR=1.0e-4
LLAMAFACTORY_NUM_EPOCHS=3.0
LLAMAFACTORY_LR_SCHEDULER_TYPE=cosine
LLAMAFACTORY_WARMUP_RATIO=0.1
LLAMAFACTORY_BF16=true
LLAMAFACTORY_LOGGING_STEPS=10
LLAMAFACTORY_SAVE_STEPS=500
LLAMAFACTORY_EVAL_STEPS=100
LLAMAFACTORY_PREPROCESSING_NUM_WORKERS=16
LLAMAFACTORY_REPORT_TO=wandb
LLAMAFACTORY_RUN_NAME=newsx-finetune-llamafactory
LLAMAFACTORY_HUB_MODEL_ID=Gamal1/news-analyzer
LLAMAFACTORY_EXPORT_HUB_MODEL_ID=Gamal1/news-analyzer
LLAMAFACTORY_HUB_PRIVATE_REPO=true
LLAMAFACTORY_HUB_STRATEGY=checkpoint

# Google Drive paths where model checkpoints are saved / loaded
# LORA_PATH is the shared adapter directory used for training output and vLLM loading.
LORA_PATH=/gdrive/MyDrive/ara-finetune/models
LORA_MODULE_NAME=news-lora

# vLLM Server Settings
VLLM_ENDPOINT=http://localhost:8000
VLLM_MODEL_ID=news-lora
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=3000

# OpenAI settings for data distillation
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
CLOUD_MODEL_ID=openai/gpt-oss-120b:free

# Local & drive dataset directory settings
RAW_DATA_PATH=/gdrive/MyDrive/ara-finetune/datasets/news-sample.jsonl
SFT_SAVE_PATH=/gdrive/MyDrive/ara-finetune/datasets/sft.jsonl
LLAMAFACTORY_DATA_DIR=/gdrive/MyDrive/ara-finetune/datasets/llamafactory-finetune-data
TRAIN_SIZE=2700

# Benchmarking & Testing
VLLM_TOKENS_FILE=./vllm_tokens.txt
DEFAULT_MODEL_TYPE=vllm
